TELEGRAM_BOT_TOKEN=
TIMEZONE=Asia/Phnom_Penh
CALENDAR_BASE_URL=https://api-calender-sigma.vercel.app/api/v1

# Optional local/shared AI keys (keys can also be added through Telegram).
# For failover pools, use comma-separated *_API_KEYS; the singular variables
# remain supported and may be used together with the pools.
GEMINI_API_KEY=
CLAUDE_API_KEY=
OPENAI_API_KEY=
ANAJAK_API_KEY=
GEMINI_API_KEYS=
CLAUDE_API_KEYS=
OPENAI_API_KEYS=
ANAJAK_API_KEYS=

# Claude via the Anajak proxy (Anthropic-shaped request body at /v1/messages,
# but an OpenAI-shaped chat-completion response). Defaults to
# https://api.anajaklabs.dev if unset.
ANAJAK_BASE_URL=

# Required for Vercel deployment. Use long, random, different values.
TELEGRAM_WEBHOOK_SECRET=
CRON_SECRET=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=