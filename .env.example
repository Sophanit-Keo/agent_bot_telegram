# Copy this file to .env and fill in the values.

# Create a bot with @BotFather in Telegram and paste the token here.
TELEGRAM_BOT_TOKEN=

# Khmer Calendar API account
CALENDAR_BASE_URL=https://api-calender-sigma.vercel.app/api/v1
CALENDAR_EMAIL=
CALENDAR_PASSWORD=

TIMEZONE=Asia/Phnom_Penh

# Optional: seed LLM API keys (can also be set from Telegram via /setkey)
GEMINI_API_KEY=
CLAUDE_API_KEY=
OPENAI_API_KEY=
